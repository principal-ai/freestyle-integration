# Copy to `.env` and fill in. `.env` is gitignored ‚Äî never commit real keys.

# Freestyle API key. The `freestyle` SDK reads this automatically.
# Get one from https://admin.freestyle.sh (or your team's Freestyle account).
FREESTYLE_API_KEY=

# GitHub token with read access to the repos under test. All default repos are
# public, so a classic token with no scopes (or even an empty value) works for
# public repos and just raises your GitHub rate limit. Required for private repos.
# It is embedded in the source URL Freestyle fetches from ‚Äî host-side only.
GITHUB_TOKEN=
